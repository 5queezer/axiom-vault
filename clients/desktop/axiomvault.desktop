[Desktop Entry]
Version=1.0
Type=Application
Name=AxiomVault
Comment=Secure encrypted vault manager
Exec=axiomvault-desktop %U
Icon=axiomvault
Categories=Utility;Security;Encryption;
Terminal=false
StartupNotify=true
X-KDE-StartupNotify=true
MimeType=x-scheme-handler/axiomvault
Keywords=vault;encryption;secure;storage;
